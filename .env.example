# ─────────────────────────────────────────────
# Netflix Content Recommender — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────

# Anthropic API key (required)
# Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Absolute or relative path to the Netflix dataset CSV file (required)
# Expected format: netflix_titles.csv (Kaggle: shivamb/netflix-shows)
DATASET_PATH=data/netflix_titles.csv

# Claude model used for preference extraction (fast, structured JSON output)
EXTRACTION_MODEL=claude-haiku-4-5-20251001

# Claude model used for recommendation response generation (higher quality prose)
GENERATION_MODEL=claude-sonnet-4-6

# Maximum number of conversation turns to retain in session history
# Older turns are dropped when this limit is reached.
MAX_HISTORY_TURNS=20

# Neon PostgreSQL connection string (optional — replaces DATASET_PATH when set)
# The database must have a table named "netflix_shows" with the Netflix catalog.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require
